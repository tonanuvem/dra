# Variáveis de ambiente — Frontend + Backend
# Copie este arquivo para .env e preencha com suas credenciais:
#   cp .env.example .env

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co

# Publishable key (substitui a antiga anon key)
# Supabase → Project Settings → API Keys → Publishable key
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key (substitui a antiga service_role key — nunca expor no frontend)
# Supabase → Project Settings → API Keys → Secret keys
SUPABASE_SECRET_KEY=sb_secret_...

# ── Frontend (Next.js) — geradas automaticamente a partir das vars acima ──────
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=${SUPABASE_PUBLISHABLE_KEY}
