# Shared Environment Variables (Frontend + Backend)
# Copy this file to .env and fill with your credentials

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key           # chave pública (leitura no frontend)
SUPABASE_SERVICE_KEY=your_service_role_key    # chave service_role (escrita pelo backend — bypassa RLS)
